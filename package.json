{
  "name": "cypress-tags-explorer",
  "displayName": "Cypress Tags Explorer",
  "description": "Manage Cypress Tags",
  "version": "0.5.0",
  "publisher": "ricowilcke",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "url": "https://github.com/Ranitzky/cypress-tags-explorer"
  },
  "categories": [
    "Testing"
  ],
  "icon": "images/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tags-explorer",
          "title": "Tags Explorer",
          "icon": "$(tag)"
        }
      ]
    },
    "views": {
      "tags-explorer": [
        {
          "id": "tags-explorer-tags",
          "name": "Tags"
        }
      ]
    },
    "commands": [
      {
        "command": "tags-explorer.open",
        "title": "Cypress Tags Explorer: Open Webview",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "tags-explorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tags-explorer.toggleViewAsTree",
        "title": "View as Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "tags-explorer.toggleViewAsList",
        "title": "View as List",
        "icon": "$(list-flat)"
      },
      {
        "command": "tags-explorer.filterTags",
        "title": "Filter Tags",
        "icon": "$(filter)"
      },
      {
        "command": "tags-explorer.editFilter",
        "title": "Edit Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "tags-explorer.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tags-explorer.refresh",
          "when": "view == tags-explorer-tags",
          "group": "navigation@1"
        },
        {
          "command": "tags-explorer.toggleViewAsTree",
          "when": "view == tags-explorer-tags && !tagsExplorer.viewAsTree",
          "group": "navigation@2"
        },
        {
          "command": "tags-explorer.toggleViewAsList",
          "when": "view == tags-explorer-tags && tagsExplorer.viewAsTree",
          "group": "navigation@2"
        },
        {
          "command": "tags-explorer.open",
          "when": "view == tags-explorer-tags",
          "group": "navigation@3"
        },
        {
          "command": "tags-explorer.filterTags",
          "when": "view == tags-explorer-tags && !tagsExplorer.isFiltered",
          "group": "navigation@4"
        },
        {
          "command": "tags-explorer.editFilter",
          "when": "view == tags-explorer-tags && tagsExplorer.isFiltered",
          "group": "navigation@4"
        },
        {
          "command": "tags-explorer.clearFilter",
          "when": "view == tags-explorer-tags && tagsExplorer.isFiltered",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Cypress Tags Explorer",
      "properties": {
        "tagsExplorer.cypressFolder": {
          "type": "string",
          "default": "cypress/e2e",
          "description": "Folder where Cypress tests are located."
        },
        "tagsExplorer.fileExtensions": {
          "type": "string",
          "default": "*.cy.ts,*.cy.js",
          "description": "Comma-separated list of test file extensions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "esbuild ./src/webview/main.ts --bundle --outfile=dist/webview.js --format=esm",
    "build:all": "npm run package && npm run build:webview",
    "build": "vsce package",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.19.2"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.2.2",
    "typescript": "^5.2.2"
  }
}
